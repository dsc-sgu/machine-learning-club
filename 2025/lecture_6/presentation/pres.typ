#slide[
    == Линейно-разделимый случай
    $
    cases(
    ||w|| -> min,
    y_i (w^T x + b) >= 0 "Требование корректной классификации",
    |w^T x + b| >= 1 "Необходимое требование для отступа"
    )
    $
]

#slide[
